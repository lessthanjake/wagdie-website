# WAGDIE-hosted official ElizaOS service
PORT=3001
HOST=0.0.0.0
DISABLE_WEB_UI=true
LOG_LEVEL=info

# Hosted/dev Compose startup must fail closed when required env is missing.
# Use ELIZAOS_ENV=local only for throwaway local spikes; Compose/dev hosts use development.
ELIZAOS_ENV=development

# Dedicated ElizaOS Postgres. This is separate from the WAGDIE Supabase app database.
ELIZA_POSTGRES_USER=elizaos
ELIZA_POSTGRES_PASSWORD=replace-with-elizaos-postgres-password
ELIZA_POSTGRES_DB=elizaos
DATABASE_URL=postgres://elizaos:replace-with-elizaos-postgres-password@elizaos-db:5432/elizaos
POSTGRES_URL=postgres://elizaos:replace-with-elizaos-postgres-password@elizaos-db:5432/elizaos
# SQLITE_PATH is local-spike only; do not use SQLite for hosted/dev validation.
# SQLITE_PATH=./data/elizaos.sqlite
ELIZAOS_DATA_DIR=/app/data

# Server-to-server auth from WAGDIE Next.js to ElizaOS.
# @elizaos/api-client sends X-API-KEY; @elizaos/server validates ELIZA_SERVER_AUTH_TOKEN for REST.
# WAGDIE app ELIZAOS_API_KEY must equal this value. It must not equal SERVER_API_KEY unless deliberately approved.
ELIZA_SERVER_AUTH_TOKEN=replace-with-long-random-token
# Required outside local development for /wagdie-knowledge/* ingestion. Keep separate from ELIZA_SERVER_AUTH_TOKEN unless intentionally shared for a short-lived smoke run.
WAGDIE_KNOWLEDGE_INGESTION_TOKEN=replace-with-separate-long-random-token
# Only for throwaway local development without a token; never set true in deployed environments.
WAGDIE_KNOWLEDGE_ALLOW_UNAUTHENTICATED_LOCAL=false
# Socket.IO/runtime auth uses SERVER_API_KEY if enabled; keep separate from the WAGDIE app credential unless the service explicitly requires sharing.
SERVER_API_KEY=replace-with-separate-elizaos-runtime-secret

# Venice provider config is owned by this ElizaOS service, not the WAGDIE Next.js app.
VENICE_API_KEY=
VENICE_BASE_URL=https://api.venice.ai/api/v1
VENICE_SMALL_MODEL=llama-3.3-70b
VENICE_LARGE_MODEL=llama-3.1-405b
VENICE_EMBEDDING_MODEL=text-embedding-bge-m3
VENICE_EMBEDDING_DIMENSIONS=1024
