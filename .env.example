# App URL (used for metadata and absolute links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (public/browser)
# These must be NEXT_PUBLIC_* for client-side access
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase (server-only, for API routes, scripts, and admin writes)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Optional legacy name (some scripts may use this)
# SUPABASE_SERVICE_KEY=your-service-role-key-here

# Database table overrides (optional)
NEXT_PUBLIC_CHARACTERS_TABLE=wagdie_characters
# CHARACTERS_TABLE=wagdie_characters

# Blockchain RPC Configuration
# Alchemy API Key for Ethereum RPC access (optional if custom RPC URLs are provided)
NEXT_PUBLIC_ALCHEMY_API_KEY=your-alchemy-api-key

# Full RPC URLs (optional, override Alchemy defaults)
NEXT_PUBLIC_ALCHEMY_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-alchemy-api-key
NEXT_PUBLIC_MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-alchemy-api-key
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-alchemy-api-key

# Server-only RPC override (used by server sync jobs)
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-alchemy-api-key

# Chain ID (1 for mainnet, 11155111 for Sepolia testnet)
NEXT_PUBLIC_CHAIN_ID=1

# Optional: Contract address overrides (client-safe)
# NEXT_PUBLIC_WAGDIE_ADDRESS=0x0000000000000000000000000000000000000000
# NEXT_PUBLIC_CONCORD_ADDRESS=0x0000000000000000000000000000000000000000
# NEXT_PUBLIC_CORPSE_ADDRESS=0x0000000000000000000000000000000000000000
# NEXT_PUBLIC_MUSHROOM_ADDRESS=0x0000000000000000000000000000000000000000
# NEXT_PUBLIC_SEARING_ADDRESS=0x0000000000000000000000000000000000000000
# NEXT_PUBLIC_SPREAD_ADDRESS=0x0000000000000000000000000000000000000000
# NEXT_PUBLIC_WAGDIE_WORLD_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: Contract address overrides (server-only)
# WAGDIE_ADDRESS=0x0000000000000000000000000000000000000000
# CONCORD_ADDRESS=0x0000000000000000000000000000000000000000
# CORPSE_ADDRESS=0x0000000000000000000000000000000000000000
# MUSHROOM_ADDRESS=0x0000000000000000000000000000000000000000
# SEARING_ADDRESS=0x0000000000000000000000000000000000000000
# SPREAD_ADDRESS=0x0000000000000000000000000000000000000000
# WAGDIE_WORLD_ADDRESS=0x0000000000000000000000000000000000000000

# Session Secret (for iron-session)
SESSION_SECRET=complex_password_at_least_32_characters_long_change_in_production

# Node Environment
NODE_ENV=development

# Ownership Sync Configuration
SYNC_SECRET_KEY=your-random-secret-key-here

# Eliza SDK
# Prefer server-only ELIZA_API_URL; NEXT_PUBLIC_ELIZA_API_URL is a fallback for client-side builds.
ELIZA_API_URL=https://eliza-api.runiverse.ai
NEXT_PUBLIC_ELIZA_API_URL=https://eliza-api.runiverse.ai
ELIZA_API_KEY=

# External Links
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/wagdie
NEXT_PUBLIC_OPENSEA_URL=https://opensea.io/collection/wagdie
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/WAGDIE_ETH
