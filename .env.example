# Supabase Configuration
# Get these from your Supabase project settings at https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Blockchain Configuration
# NOTE: WalletConnect has been removed - only browser extension wallets supported
# (MetaMask, Coinbase Wallet, etc.)
# Alchemy API Key for Ethereum RPC access
NEXT_PUBLIC_ALCHEMY_API_KEY=your-alchemy-api-key

# Full RPC URL (optional, defaults to Alchemy if API key is provided)
NEXT_PUBLIC_ALCHEMY_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-alchemy-api-key

# Sepolia testnet RPC URL (optional, defaults to Alchemy if API key is provided)
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-alchemy-api-key

# Chain ID (1 for mainnet, 11155111 for Sepolia testnet)
# Default is 1 (mainnet)
NEXT_PUBLIC_CHAIN_ID=1

# Optional: Custom contract addresses (overrides defaults)
# Only use these if you need to test with different contract deployments
# NEXT_PUBLIC_WAGDIE_ADDRESS=0x659a4bdaaacc62d2bd9cb18225d9c89b5b697a5a
# NEXT_PUBLIC_CONCORD_ADDRESS=0x1d38150f1fd989fb89ab19518a9c4e93c5554634
# NEXT_PUBLIC_CORPSE_ADDRESS=0x21fc8585eee37be572a0e37c34c7ad2a15a36ee3
# NEXT_PUBLIC_MUSHROOM_ADDRESS=0x171a8518A1B75F9E26ea952728d4850BEf9B87d2
# NEXT_PUBLIC_SEARING_ADDRESS=0x5156A7F668E59119db23a264502F40407CDa076F
# NEXT_PUBLIC_SPREAD_ADDRESS=0xaCA80514986768F88F7d8E644546AB85383ddE7e
# NEXT_PUBLIC_WAGDIE_WORLD_ADDRESS=0x616D4635ceCf94597690Cab0Fc159c3A8231C904

# Session Secret (for iron-session)
# Generate a secure 32+ character string for production
SESSION_SECRET=complex_password_at_least_32_characters_long_change_in_production

# Node Environment
NODE_ENV=development

# Ownership Sync Configuration
# Secret key for authenticating sync API requests (generate a random string)
SYNC_SECRET_KEY=your-random-secret-key-here

# Supabase Service Role Key (for server-side database writes)
# Get this from your Supabase project settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
