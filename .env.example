# Supabase Configuration
# Get these from your Supabase project settings at https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# WalletConnect Configuration
# Get a free project ID from https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# Optional: Blockchain RPC endpoints
NEXT_PUBLIC_ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-api-key

# Optional: Contract addresses
NEXT_PUBLIC_WAGDIE_CONTRACT_ADDRESS=0x...
NEXT_PUBLIC_BEASTS_CONTRACT_ADDRESS=0x...

# Session Secret (for iron-session)
# Generate a secure 32+ character string for production
SESSION_SECRET=complex_password_at_least_32_characters_long_change_in_production

# Node Environment
NODE_ENV=development
