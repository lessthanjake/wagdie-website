# App URL (used for metadata and absolute links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (public/browser)
# These must be NEXT_PUBLIC_* for client-side access
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase (server-only, for API routes, scripts, and admin writes)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Optional legacy name (some scripts may use this)
# SUPABASE_SERVICE_KEY=your-service-role-key-here

# Database table overrides (optional)
NEXT_PUBLIC_CHARACTERS_TABLE=wagdie_characters
# CHARACTERS_TABLE=wagdie_characters

# Blockchain RPC Configuration
# Alchemy API Key for Ethereum RPC access (optional if custom RPC URLs are provided)
NEXT_PUBLIC_ALCHEMY_API_KEY=your-alchemy-api-key

# Full RPC URLs (optional, override Alchemy defaults)
NEXT_PUBLIC_ALCHEMY_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-alchemy-api-key
NEXT_PUBLIC_MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-alchemy-api-key
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-alchemy-api-key

# Server-only RPC override (used by server sync jobs)
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-alchemy-api-key

# Chain ID (1 for mainnet, 11155111 for Sepolia testnet)
NEXT_PUBLIC_CHAIN_ID=1

# Optional: Contract address overrides (client-safe)
# NEXT_PUBLIC_WAGDIE_ADDRESS=0x0000000000000000000000000000000000000000
# NEXT_PUBLIC_CONCORD_ADDRESS=0x0000000000000000000000000000000000000000
# NEXT_PUBLIC_CORPSE_ADDRESS=0x0000000000000000000000000000000000000000
# NEXT_PUBLIC_MUSHROOM_ADDRESS=0x0000000000000000000000000000000000000000
# NEXT_PUBLIC_SEARING_ADDRESS=0x0000000000000000000000000000000000000000
# NEXT_PUBLIC_SPREAD_ADDRESS=0x0000000000000000000000000000000000000000
# NEXT_PUBLIC_WAGDIE_WORLD_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: Contract address overrides (server-only)
# WAGDIE_ADDRESS=0x0000000000000000000000000000000000000000
# CONCORD_ADDRESS=0x0000000000000000000000000000000000000000
# CORPSE_ADDRESS=0x0000000000000000000000000000000000000000
# MUSHROOM_ADDRESS=0x0000000000000000000000000000000000000000
# SEARING_ADDRESS=0x0000000000000000000000000000000000000000
# SPREAD_ADDRESS=0x0000000000000000000000000000000000000000
# WAGDIE_WORLD_ADDRESS=0x0000000000000000000000000000000000000000

# Session Secret (for iron-session)
SESSION_SECRET=complex_password_at_least_32_characters_long_change_in_production

# Node Environment
NODE_ENV=development

# Ownership Sync Configuration
SYNC_SECRET_KEY=your-random-secret-key-here

# Eliza SDK
# Keep these pointed at the Eliza API for auth, character records, and conversations.
# Prefer server-only ELIZA_API_URL; NEXT_PUBLIC_ELIZA_API_URL is a fallback for client-side builds.
ELIZA_API_URL=https://eliza-api.runiverse.ai
NEXT_PUBLIC_ELIZA_API_URL=https://eliza-api.runiverse.ai
ELIZA_API_KEY=

# Official ElizaOS migration controls (server-only; not used by browser code)
# legacy = current custom gateway, dual = legacy visible + official shadow/canary, official = official primary.
# Dev Compose keeps ELIZA_INTEGRATION_MODE=legacy until direct ElizaOS smoke passes; set official for Work Item 5.
# Compose app URL is ELIZAOS_BASE_URL=http://elizaos:3001; host-shell smoke scripts use http://localhost:3001.
ELIZA_INTEGRATION_MODE=legacy
ELIZAOS_BASE_URL=http://localhost:3001
# Must equal the ElizaOS service ELIZA_SERVER_AUTH_TOKEN. In docker-compose.yml this is mapped
# from ELIZA_SERVER_AUTH_TOKEN so the WAGDIE app never needs SERVER_API_KEY or VENICE_API_KEY.
ELIZAOS_API_KEY=replace-with-same-value-as-eliza-server-auth-token
ELIZAOS_HEALTH_PATH=/api/server/health

# ElizaOS service/deployment secret names (service-side only; never NEXT_PUBLIC_*).
# Store real values in the dev host secret store or an untracked deployment env file.
# ELIZA_SERVER_AUTH_TOKEN=replace-with-long-random-token
# WAGDIE_KNOWLEDGE_INGESTION_TOKEN=replace-with-separate-long-random-token
# SERVER_API_KEY=replace-with-separate-elizaos-runtime-secret
# VENICE_API_KEY=replace-with-venice-provider-key-service-only
# ELIZA_POSTGRES_USER=elizaos
# ELIZA_POSTGRES_PASSWORD=replace-with-elizaos-postgres-password
# ELIZA_POSTGRES_DB=elizaos

# WAGDIE Supabase migration validation target (the app database, not the ElizaOS Postgres).
# The validation script requires an explicit non-production target label before it will run.
# ELIZA_DB_VALIDATION_TARGET_ENV=dev
# Required for remote dev/staging targets unless ELIZA_DB_VALIDATION_ALLOW_UNVERIFIED_TARGET=true is intentionally set.
# ELIZA_DB_VALIDATION_EXPECT_SUPABASE_REF=your-dev-project-ref
# ELIZA_DB_VALIDATION_ALLOW_UNVERIFIED_TARGET=true
# SUPABASE_DB_URL=postgres://postgres:<password>@db.<your-dev-project-ref>.supabase.co:5432/postgres

# Optional legacy Venice inference for the current custom Eliza chat streaming path.
# Official ElizaOS Venice/provider secrets belong in the ElizaOS service secret store, not here.
# Venice is OpenAI-compatible; chat requests go to {ELIZA_LLM_BASE_URL}/chat/completions.
ELIZA_LLM_BASE_URL=https://api.venice.ai/api/v1
ELIZA_LLM_API_KEY=
ELIZA_LLM_MODEL=
# ELIZA_LLM_TEMPERATURE=0.8
# ELIZA_LLM_MAX_TOKENS=1000

# External Links
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/wagdie
NEXT_PUBLIC_OPENSEA_URL=https://opensea.io/collection/wagdie
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/WAGDIE_ETH

# Optional local dev API proxy
# Set this in `.env.local` when you want local frontend requests to `/api/*`
# to be served by a deployed WAGDIE instance instead of local Next API routes.
# Example: WAGDIE_API_BASE_URL=https://your-deployed-wagdie-app.example.com
# WAGDIE_API_BASE_URL=
